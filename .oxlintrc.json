{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "ignorePatterns": ["examples/basic-nest/src/metadata.ts"],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "rules": {
    "typescript/no-extraneous-class": ["error", { "allowWithDecorator": true }]
  },
  "options": {
    "denyWarnings": true,
    "typeAware": true,
    "typeCheck": true
  },
  "env": {
    "builtin": true
  }
}
