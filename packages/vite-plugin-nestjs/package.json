{
  "name": "vite-plugin-nestjs",
  "version": "0.3.1",
  "description": "Vite plugin to run NestJS apps with ESM, any Vite plugins, and optional Swagger metadata generation.",
  "keywords": [
    "nestjs",
    "swagger",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/Alan-Gomes/vite-plugin-nestjs#readme",
  "bugs": {
    "url": "https://github.com/Alan-Gomes/vite-plugin-nestjs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alan-Gomes/vite-plugin-nestjs.git",
    "directory": "packages/vite-plugin-nestjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "cp ../../README.md README.md"
  },
  "dependencies": {
    "remeda": "^2.34.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@types/node": "^22.19.19",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "peerDependencies": {
    "@nestjs/cli": ">=10",
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "@nestjs/swagger": ">=7",
    "vite": "^8.0.13"
  },
  "peerDependenciesMeta": {
    "@nestjs/cli": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    }
  }
}
