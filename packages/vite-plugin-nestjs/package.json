{
  "name": "vite-plugin-nestjs",
  "version": "0.1.0",
  "description": "Vite plugin to run NestJS with native ESM, Vite plugin ecosystem support, and automatic @nestjs/swagger metadata generation",
  "keywords": [
    "nestjs",
    "swagger",
    "vite",
    "vite-plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alan-Gomes/vite-plugin-nestjs.git",
    "directory": "packages/vite-plugin-nestjs"
  },
  "bugs": {
    "url": "https://github.com/Alan-Gomes/vite-plugin-nestjs/issues"
  },
  "homepage": "https://github.com/Alan-Gomes/vite-plugin-nestjs#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "@nestjs/cli": ">=10",
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "@nestjs/swagger": ">=7",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/cli": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    }
  }
}
