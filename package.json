{
  "name": "vite-plugin-nestjs-monorepo",
  "private": true,
  "description": "Monorepo for vite-plugin-nestjs",
  "homepage": "https://github.com/Alan-Gomes/vite-plugin-nestjs#readme",
  "bugs": {
    "url": "https://github.com/Alan-Gomes/vite-plugin-nestjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Alan-Gomes/vite-plugin-nestjs.git"
  },
  "type": "module",
  "scripts": {
    "postinstall": "lefthook install",
    "build": "pnpm --filter vite-plugin-nestjs build",
    "dev:example": "pnpm --filter basic-nest dev",
    "build:example": "pnpm --filter basic-nest build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "execa": "^9.6.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "esbuild"
    ]
  }
}
